# search-service env

# Server
PORT=3003
NODE_ENV=development

# Elasticsearch
ELASTICSEARCH_URL=http://localhost:9200

# Index naming — alias `products` swaps between versioned indexes for zero-downtime reindex
ES_INDEX_ALIAS=products
ES_INDEX_VERSION=v1

# RabbitMQ — subscriber for `product.indexed` topic events
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Catalog service — used to enrich product documents on event + bulk reindex
CATALOG_SERVICE_URL=http://localhost:3002

# Auth — base64 SPKI PEM (shared with auth-service); required for POST /reindex admin guard
AUTH_PUBLIC_KEY_B64=

# Reindex/bulk tuning
REINDEX_BATCH_SIZE=500
REINDEX_FETCH_PAGE_SIZE=50

# Storefront default currency (used when ?currency= omitted from search query)
DEFAULT_CURRENCY=USD
