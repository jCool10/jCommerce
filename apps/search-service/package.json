{
  "name": "@jcool/search-service",
  "version": "0.1.0",
  "private": true,
  "description": "Search microservice — Elasticsearch-backed full-text + facets + autocomplete; consumes product.indexed events from catalog (NestJS).",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "seed:search": "node dist/main.js reindex",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@elastic/elasticsearch": "^8.15.1",
    "@jcool/contracts": "workspace:*",
    "@jcool/nest-kit": "workspace:*",
    "@jcool/observability": "workspace:*",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "@nestjs/platform-express": "^10.4.7",
    "amqplib": "^0.10.4",
    "jose": "^5.9.6",
    "nest-commander": "^3.15.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "undici": "^6.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jcool/eslint-config": "workspace:*",
    "@jcool/tsconfig": "workspace:*",
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@types/amqplib": "^0.10.5",
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "^2.1.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
