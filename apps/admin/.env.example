# API gateway is the only ingress; admin calls v1 routes through it.
NEXT_PUBLIC_API_BASE_URL=http://localhost:3000/api/v1
GATEWAY_INTERNAL_URL=http://localhost:3000/api/v1

# NextAuth v5: secret used to sign session JWT (generate via `openssl rand -base64 32`)
AUTH_SECRET=change-me-in-prod
NEXTAUTH_URL=http://localhost:3101

# Optional: long-lived dev override allowing customer login redirect tweaks
ADMIN_ALLOWED_ROLES=admin
