{
  "name": "@jcool/email-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Email worker — consumes order.confirmed RabbitMQ events, enqueues BullMQ jobs, renders MJML/Handlebars templates, sends via SMTP (Mailhog dev / SendGrid prod).",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@jcool/contracts": "workspace:*",
    "@jcool/observability": "workspace:*",
    "@nestjs/common": "^10.4.7",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.7",
    "amqplib": "^0.10.4",
    "bullmq": "^5.21.2",
    "handlebars": "^4.7.8",
    "mjml": "^4.15.3",
    "nodemailer": "^6.9.16",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jcool/eslint-config": "workspace:*",
    "@jcool/tsconfig": "workspace:*",
    "@nestjs/cli": "^10.4.7",
    "@nestjs/schematics": "^10.2.3",
    "@types/amqplib": "^0.10.5",
    "@types/mjml": "^4.7.4",
    "@types/node": "^22.9.0",
    "@types/nodemailer": "^6.4.16",
    "@vitest/coverage-v8": "^2.1.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
