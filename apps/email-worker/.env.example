# email-worker (phase 9) — copy to .env at repo root or inherit from root .env

# RabbitMQ (consumer)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Redis (BullMQ store) — db index 3 reserved for email queues
EMAIL_WORKER_REDIS_URL=redis://localhost:6379/3

# BullMQ
EMAIL_QUEUE_NAME=email
EMAIL_QUEUE_CONCURRENCY=4

# SMTP (Mailhog dev / SendGrid|Mailgun prod via phase 15)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@jcool.local
SMTP_FROM_NAME=jCool Store
SMTP_SECURE=false

# Escape hatches
EMAIL_DISABLE_CONSUMER=0
EMAIL_DISABLE_WORKER=0
