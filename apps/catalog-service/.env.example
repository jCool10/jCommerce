# catalog-service env

# Server
PORT=3002
NODE_ENV=development

# Database — dedicated logical DB on shared Postgres instance
DATABASE_URL_CATALOG=postgresql://postgres:postgres@localhost:5432/catalog_db?schema=public

# RabbitMQ — outbox poller publishes domain events to the topic exchange
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Redis — cache-aside layer for hot product reads (dedicated logical DB index)
CATALOG_REDIS_URL=redis://localhost:6379/3
# How long a cached product stays warm before it must be re-read from Postgres
PRODUCT_CACHE_TTL_SECONDS=300

# Auth — base64-encoded RS256 public key (shared with auth-service)
AUTH_PUBLIC_KEY_B64=

# Outbox poller cadence (cron expression, every-second by default)
OUTBOX_POLL_CRON=*/1 * * * * *
OUTBOX_BATCH_SIZE=100

# Storefront default currency (used when ?currency= query param omitted)
DEFAULT_CURRENCY=USD

# Seed
SEED_PRODUCT_COUNT=180
