# api-gateway env (phase 10)

# Server — main.ts honors GATEWAY_PORT before PORT (mirrors order-service).
GATEWAY_PORT=3000
NODE_ENV=development

# Auth — RS256 public key for verifying access tokens issued by auth-service
# Shared via AUTH_PUBLIC_KEY_B64 (same env var name as every other consumer)
AUTH_PUBLIC_KEY_B64=

# Downstream service URLs (proxy targets)
AUTH_SERVICE_URL=http://localhost:3001
CATALOG_SERVICE_URL=http://localhost:3002
SEARCH_SERVICE_URL=http://localhost:3003
ORDER_SERVICE_URL=http://localhost:3004

# Rate-limit Redis store (separate logical db so it does not collide with
# auth=0, search=1, order=2, email=3)
GATEWAY_REDIS_URL=redis://localhost:6379/4

# CORS — comma-separated allowlist of storefront/admin origins
CORS_ORIGINS=http://localhost:3100,http://localhost:3101

# Proxy timeouts (ms)
PROXY_HEADERS_TIMEOUT_MS=10000
PROXY_BODY_TIMEOUT_MS=30000
