# auth-service env

# Server
PORT=3001
NODE_ENV=development

# Database — connects to the shared Postgres instance, dedicated logical DB
DATABASE_URL_AUTH=postgresql://postgres:postgres@localhost:5432/auth_db?schema=public

# Redis — refresh-token blocklist
AUTH_REDIS_URL=redis://localhost:6379/0

# JWT — RS256 (PEM, base64-encoded so .env stays single-line). Generate with:
#   openssl genrsa -out priv.pem 2048 && openssl rsa -in priv.pem -pubout -out pub.pem
#   then `base64 -i priv.pem` / `base64 -i pub.pem`
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ISSUER=jcool-auth
JWT_AUDIENCE=jcool-clients

# bcrypt cost — keep 12 in prod, drop to 4 in tests
BCRYPT_COST=12

# Admin bootstrap seed — idempotent on first migrate or via `pnpm --filter @jcool/auth-service seed:admin`
ADMIN_EMAIL=admin@jcool.local
ADMIN_PASSWORD=ChangeMe!Strong123
