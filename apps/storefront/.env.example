# ─── storefront (phase 11) ───────────────────────────────────────────────
# All requests go through the API gateway at /api/v1/* (phase 10).
NEXT_PUBLIC_API_URL=http://localhost:3000

# NextAuth v5 — REQUIRED. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=changeme-generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3100

# Stripe (publishable key is browser-safe; secret stays on the server side
# only — checkout creates the PaymentIntent via the order-service).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Server-side fallback when calling the gateway from Server Components.
# Defaults to NEXT_PUBLIC_API_URL when unset; override in Docker to use
# the internal hostname (e.g. http://api-gateway:3000).
INTERNAL_API_URL=
