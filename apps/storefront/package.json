{
  "name": "@jcool/storefront",
  "version": "0.1.0",
  "private": true,
  "description": "Public-facing Next.js 14 storefront — App Router, NextAuth v5, Tailwind, Stripe Elements.",
  "scripts": {
    "build": "next build",
    "dev": "next dev -p 3100",
