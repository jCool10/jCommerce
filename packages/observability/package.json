{
  "name": "@jcool/observability",
  "version": "0.1.0",
  "private": true,
  "description": "Shared observability primitives: Pino logger w/ PII redaction, prom-client metrics, OpenTelemetry tracing, NestJS glue.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./tracing-bootstrap": {
      "types": "./dist/tracing-bootstrap.d.ts",
      "import": "./dist/tracing-bootstrap.js",
      "require": "./dist/tracing-bootstrap.cjs",
      "default": "./dist/tracing-bootstrap.js"
    },
    "./sentry-init": {
      "types": "./dist/sentry-init.d.ts",
      "import": "./dist/sentry-init.js",
      "require": "./dist/sentry-init.cjs",
      "default": "./dist/sentry-init.js"
    },
    "./dist/*": "./dist/*"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "prom-client": "^15.1.3",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/sdk-node": "^0.55.0",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.55.0",
    "@opentelemetry/resources": "^1.28.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "@opentelemetry/propagator-b3": "^1.28.0",
    "@sentry/node": "^8.45.0"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "@nestjs/core": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@jcool/eslint-config": "workspace:*",
    "@jcool/tsconfig": "workspace:*",
    "@nestjs/common": "^10.4.7",
    "@nestjs/core": "^10.4.7",
    "@types/node": "^22.9.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
