{
  "name": "@jcool/nest-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Shared NestJS HTTP primitives (guards, pipes) reused across jCool backend services.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0",
    "reflect-metadata": "^0.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@jcool/eslint-config": "workspace:*",
    "@jcool/tsconfig": "workspace:*",
    "@nestjs/common": "^10.4.7",
    "@types/node": "^22.9.0",
    "reflect-metadata": "^0.2.2",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "zod": "^3.23.8"
  }
}
