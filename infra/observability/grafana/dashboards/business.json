{
  "uid": "jcool-business",
  "title": "jCool — Business",
  "tags": ["jcool", "business", "kpi"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Orders per minute (by status)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (rate(orders_created_total[1m]) * 60)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Revenue per hour (subunit, by currency)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (currency) (increase(revenue_subunit_total[1h]))",
          "legendFormat": "{{currency}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total orders today",
      "gridPos": { "h": 6, "w": 8, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(increase(orders_created_total[24h]))"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Compensations today",
      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(increase(saga_compensations_total[24h]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Inventory reservations today",
      "gridPos": { "h": 6, "w": 8, "x": 16, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (result) (increase(inventory_reserved_total[24h]))",
          "legendFormat": "{{result}}"
        }
      ]
    }
  ]
}
