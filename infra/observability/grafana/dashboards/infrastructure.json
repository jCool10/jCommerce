{
  "uid": "jcool-infrastructure",
  "title": "jCool — Infrastructure",
  "tags": ["jcool", "infra", "rabbitmq", "bullmq", "db"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "RabbitMQ messages published / min",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (routingKey) (rate(rabbitmq_messages_published_total[1m]) * 60)",
          "legendFormat": "{{routingKey}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "RabbitMQ consume status / min",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (queue, status) (rate(rabbitmq_messages_consumed_total[1m]) * 60)",
          "legendFormat": "{{queue}}/{{status}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "BullMQ job duration p95 (s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, queue, name) (rate(bullmq_job_duration_seconds_bucket[5m])))",
          "legendFormat": "{{queue}}/{{name}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "BullMQ failed jobs / min",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (queue, name) (rate(bullmq_job_failed_total[1m]) * 60)",
          "legendFormat": "{{queue}}/{{name}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "DB query p95 latency (s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service, table, operation) (rate(db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}}/{{table}}/{{operation}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Node.js event loop lag (s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "{{service}}"
        }
      ]
    }
  ]
}
