{
  "uid": "jcool-saga-health",
  "title": "jCool — Saga Health",
  "tags": ["jcool", "saga", "checkout"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Orders created (1h, by status)",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (status) (increase(orders_created_total[1h]))",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Revenue (subunit, 1h, by currency)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (currency) (increase(revenue_subunit_total[1h]))",
          "legendFormat": "{{currency}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Saga compensations / min",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (step) (rate(saga_compensations_total[1m]) * 60)",
          "legendFormat": "{{step}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Outbox pending depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "outbox_events_pending",
          "legendFormat": "{{source}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Inventory reservations (reserved vs rejected, /min)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum by (result) (rate(inventory_reserved_total[1m]) * 60)",
          "legendFormat": "{{result}}"
        }
      ]
    }
  ]
}
