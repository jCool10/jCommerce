dist
build
out
.next
.turbo
*.tsbuildinfo
# next-env.d.ts is regenerated on next dev/build — never edit, never commit.
next-env.d.ts

coverage
.nyc_output

# pnpm-lock.yaml is the source of truth.
package-lock.json
yarn.lock

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
logs.txt

# .env.example IS the contract — keep it tracked.
.env
.env.*
!.env.example

*.pem
*.key
*.p12

.DS_Store
Thumbs.db
.idea/
.vscode/*
