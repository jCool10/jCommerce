# Root .env.example — connection strings filled per-service in phase 2+
# Service-specific .env.example lives in apps/<service>/.env.example

# Node env
NODE_ENV=development

# ─── Observability (phase 14) ────────────────────────────────────────────
# Pino: 'fatal'|'error'|'warn'|'info'|'debug'|'trace'
LOG_LEVEL=info
# Sampling for info-level logs in prod (0..1). errors/warns always 100%.
LOG_INFO_SAMPLE_RATE=1
# OpenTelemetry OTLP exporter (Tempo via the o11y stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# Disable OTel SDK entirely (CLI seeds / unit tests).
OTEL_SDK_DISABLED=0
# email-worker /metrics port (it has no NestJS HTTP adapter).
METRICS_PORT=9100
# Build SHA stamped on traces + future Sentry releases.
GIT_SHA=

# Sentry — leave SENTRY_DSN blank in dev/test; the SDK becomes a silent
# no-op and OTel/Pino keep functioning. Set in prod via secret manager.
# Per-frontend keys (NEXT_PUBLIC_*) need separate Sentry projects so the
# browser SDK doesn't expose backend project tokens.
SENTRY_DSN=
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=
NEXT_PUBLIC_SENTRY_DSN_STOREFRONT=
NEXT_PUBLIC_SENTRY_DSN_ADMIN=

# Postgres (shared host; per-service DBs created by infra/postgres/init.sql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
# RabbitMQ Management HTTP API — used by the DLQ depth Prometheus collector
# (order-service polls every 30 s; depth > 0 triggers RabbitMQDLQHasMessages alert)
RABBITMQ_MGMT_URL=http://localhost:15672
RABBITMQ_MGMT_USER=guest
RABBITMQ_MGMT_PASS=guest

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200

# Mailhog (dev SMTP)
SMTP_HOST=localhost
SMTP_PORT=1025

# ─── auth-service (phase 4) ──────────────────────────────────────────────
DATABASE_URL_AUTH=postgresql://postgres:postgres@localhost:5432/auth_db?schema=public
AUTH_REDIS_URL=redis://localhost:6379/0

# JWT RS256 (base64-encoded PEMs). Generate:
#   openssl genrsa -out priv.pem 2048
#   openssl rsa -in priv.pem -pubout -out pub.pem
#   base64 -i priv.pem | tr -d '\n'
#   base64 -i pub.pem  | tr -d '\n'
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800
JWT_ISSUER=jcool-auth
JWT_AUDIENCE=jcool-clients

# bcrypt: 12 in prod, 4 in tests
BCRYPT_COST=12

# Admin bootstrap seed — idempotent (runs only if admin missing)
ADMIN_EMAIL=admin@jcool.local
ADMIN_PASSWORD=ChangeMe!Strong123

# ─── search-service (phase 6) ────────────────────────────────────────────
# Inherits ELASTICSEARCH_NODE / RABBITMQ_URL above.
ELASTICSEARCH_URL=http://localhost:9200
ES_INDEX_ALIAS=products
ES_INDEX_VERSION=v1
CATALOG_SERVICE_URL=http://localhost:3002
REINDEX_BATCH_SIZE=500
REINDEX_FETCH_PAGE_SIZE=50

# ─── order-service (phase 7) ─────────────────────────────────────────────
# Postgres DB is created by infra/postgres/init.sql (order_db).
DATABASE_URL_ORDER=postgresql://postgres:postgres@localhost:5432/order_db?schema=public
# Inherits CATALOG_SERVICE_URL above; auth public key shared via AUTH_PUBLIC_KEY_B64.
AUTH_PUBLIC_KEY_B64=
ORDER_REDIS_URL=redis://localhost:6379/2
ORDER_PORT=3004
ORDER_OUTBOX_BATCH_SIZE=100
CART_TTL_SECONDS=604800
CATALOG_HTTP_TIMEOUT_HEADERS_MS=5000
CATALOG_HTTP_TIMEOUT_BODY_MS=10000
# Stripe (test mode). Webhook secret is printed by `make stripe-listen`
# on first run — paste into STRIPE_WEBHOOK_SECRET below. Missing keys
# fail lazily at first paymentIntents.create / webhook delivery rather
# than at boot, so unrelated dev flows still run.
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── email-worker (phase 9) ──────────────────────────────────────────────
# Consumes `order.confirmed` events → BullMQ job → MJML render → SMTP send.
# Reuses RABBITMQ_URL above. Redis db index 3 is reserved for email queues
# (auth=0, order=2, search=1 already in use).
EMAIL_WORKER_REDIS_URL=redis://localhost:6379/3
EMAIL_QUEUE_NAME=email
EMAIL_QUEUE_CONCURRENCY=4
# SMTP fields share names with the Mailhog block above; override here if
# the worker needs distinct creds (prod: SendGrid/Mailgun in phase 15).
SMTP_FROM=no-reply@jcool.local
SMTP_FROM_NAME=jCool Store
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# Escape hatches for partial bring-up during dev:
EMAIL_DISABLE_CONSUMER=0
EMAIL_DISABLE_WORKER=0
# DANGER: bypasses the DevUserEmailResolver production guard. Leave at 0
# until the gateway-backed real adapter ships in phase 10.
ALLOW_DEV_EMAIL_RESOLVER=0

# ─── api-gateway (phase 10) ──────────────────────────────────────────────
# Reverse proxy: validates JWT, injects user headers, applies rate limits,
# routes /api/v1/{auth,catalog,products,orders,checkout,cart,search}/* to
# the right backing service. Inherits AUTH_PUBLIC_KEY_B64 above.
# GATEWAY_PORT overrides PORT inside main.ts so multiple Node services can
# share the same shell session without colliding on $PORT.
GATEWAY_PORT=3000
AUTH_SERVICE_URL=http://localhost:3001
# CATALOG_SERVICE_URL / ORDER_SERVICE_URL already set above.
SEARCH_SERVICE_URL=http://localhost:3003
# Dedicated Redis db for throttler counters (auth=0, search=1, order=2,
# email=3 already in use).
GATEWAY_REDIS_URL=redis://localhost:6379/4
# Comma-separated origins for storefront/admin during dev.
CORS_ORIGINS=http://localhost:3100,http://localhost:3101
PROXY_HEADERS_TIMEOUT_MS=10000
PROXY_BODY_TIMEOUT_MS=30000

# ─── storefront (phase 11) ───────────────────────────────────────────────
# Public-facing Next.js 14. All traffic goes through the gateway.
NEXT_PUBLIC_API_URL=http://localhost:3000
# Server-side override when the storefront and gateway share a docker network.
INTERNAL_API_URL=
# NextAuth v5 — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3100
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Set to any truthy value to show the "Continue with Google" button in the UI.
NEXT_PUBLIC_GOOGLE_ENABLED=
# Browser-safe Stripe publishable key (test mode).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
# Optional: absolute site URL used by sitemap + OG metadata.
NEXT_PUBLIC_SITE_URL=http://localhost:3100
